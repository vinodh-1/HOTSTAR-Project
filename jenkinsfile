pipeline {
    agent any

    stages {

        stage('Git Checkout') {
            steps {
                checkout scmGit(
                    branches: [[name: '*/main']],
                    extensions: [],
                    userRemoteConfigs: [[
                        credentialsId: 'vinodh',
                        url: 'https://github.com/vinodh-1/HOTSTAR-Project.git'
                    ]]
                )
            }
        }

        stage('Validate') {
            steps {
                sh 'mvn validate'
            }
        }

        stage('Compile') {
            steps {
                sh 'mvn compile'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Package Artifact') {
            steps {
                sh 'mvn package'
            }
        }
    }
}
